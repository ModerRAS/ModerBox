<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ModerBox.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="ModerBox.Views.UserControls.SwitchOperationReport"
             x:DataType="vm:SwitchOperationReportViewModel">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="15" MaxWidth="900" HorizontalAlignment="Left">

            <!-- 标题 -->
            <TextBlock Text="分合闸操作报表导出"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <!-- 数据库文件选择 -->
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="15">
                <StackPanel Spacing="10">
                    <TextBlock Text="文件设置" FontWeight="Bold"/>

                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                        <TextBox Grid.Row="0" Grid.Column="0"
                                 Watermark="SQLite 数据库文件路径（通常为“滤波器分合闸波形检查.sqlite”）"
                                 Text="{Binding DbFile}" Margin="0,0,10,0"/>
                        <Button Grid.Row="0" Grid.Column="1"
                                Command="{Binding SelectDbFile}"
                                Content="选择文件"/>

                        <TextBox Grid.Row="1" Grid.Column="0"
                                 Watermark="导出文件路径 (.xlsx)"
                                 Text="{Binding TargetFile}" Margin="0,10,10,0"/>
                        <Button Grid.Row="1" Grid.Column="1"
                                Command="{Binding SelectTargetFile}"
                                Content="选择文件" Margin="0,10,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 时间范围选择 -->
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="15">
                <StackPanel Spacing="10">
                    <TextBlock Text="时间范围" FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <StackPanel>
                            <TextBlock Text="开始时间"/>
                            <DatePicker SelectedDate="{Binding StartDate}" Margin="0,5,0,0"/>
                            <TimePicker SelectedTime="{Binding StartTime}" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="结束时间"/>
                            <DatePicker SelectedDate="{Binding EndDate}" Margin="0,5,0,0"/>
                            <TimePicker SelectedTime="{Binding EndTime}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="将导出选定时间范围内每个开关的最后七次分闸和合闸记录"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </Border>

            <!-- 开关数据源配置 -->
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="15">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="合闸数据源配置" FontWeight="Bold"/>
                        <Button Command="{Binding ApplyDefaultMapping}"
                                Content="应用默认映射"
                                Padding="10,2"/>
                        <TextBlock Text="(5开头→选相合闸，T开头→合闸电阻，其他→时间间隔)"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                    <!-- 表格头部 -->
                    <Grid ColumnDefinitions="120, *, *, *" Margin="0,10,0,0" 
                          IsVisible="{Binding HasLoadedSwitches}">
                        <TextBlock Grid.Column="0" Text="开关名称" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="时间间隔" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="选相合闸" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="合闸电阻" FontWeight="SemiBold" TextAlignment="Center"/>
                    </Grid>

                    <!-- 开关列表 -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1" CornerRadius="4" MaxHeight="300"
                            IsVisible="{Binding HasLoadedSwitches}">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding SwitchDataSources}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SwitchDataSourceItemViewModel">
                                        <Grid ColumnDefinitions="120, *, *, *" Margin="5">
                                            <TextBlock Grid.Column="0" Text="{Binding SwitchName}" 
                                                       VerticalAlignment="Center"/>
                                            <RadioButton Grid.Column="1" 
                                                         IsChecked="{Binding UseTimeInterval}"
                                                         GroupName="{Binding SwitchName}"
                                                         HorizontalAlignment="Center"/>
                                            <RadioButton Grid.Column="2" 
                                                         IsChecked="{Binding UseVoltageZeroCrossing}"
                                                         GroupName="{Binding SwitchName}"
                                                         HorizontalAlignment="Center"/>
                                            <RadioButton Grid.Column="3" 
                                                         IsChecked="{Binding UseClosingResistor}"
                                                         GroupName="{Binding SwitchName}"
                                                         HorizontalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- 加载中 -->
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoadingSwitches}"
                                 MaxWidth="200" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- 操作按钮与状态 -->
            <StackPanel Spacing="10">
                <Button Command="{Binding RunExport}"
                        Classes="accent"
                        Content="导出报表"
                        IsEnabled="{Binding !IsRunning}"
                        Width="120" HorizontalContentAlignment="Center"/>

                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
